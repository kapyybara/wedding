# Firebase config — lấy từ Project settings > General > Your apps trong Firebase Console.
# Copy file này thành .env.local rồi điền giá trị thật (không commit .env.local).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
